# ── Anthropic ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── GitHub wiki repo ──────────────────────────────────
# Create a repo called "projectx-wiki" on GitHub, then generate
# a Personal Access Token with repo scope
GITHUB_TOKEN=ghp_your-token-here
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=projectx-wiki
GITHUB_BRANCH=main

# ── Microsoft SSO (Azure AD) ──────────────────────────
# Register an app in Azure AD → App Registrations
# Redirect URI: https://your-domain.com/auth/microsoft/callback
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-secret
MICROSOFT_TENANT_ID=your-tenant-id-or-common

# ── Google OAuth (optional fallback) ──────────────────
# console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── App config ────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string-in-production
BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# ── Access control ─────────────────────────────────────
# Comma-separated email lists per role
# Executive: read-only curated digest view
EXEC_EMAILS=piyush.manocha@accenture.com,josh.naffman@diageo.com,patrick.teske@diageo.com
# Delivery leads: full read + write + AI commands
LEAD_EMAILS=avishek.saha@accenture.com,you@accenture.com
# Diageo partners: read specific shared pages only
DIAGEO_EMAILS=sud@diageo.com,ian.curd@diageo.com,karla.castro@diageo.com
# Everyone else with a matching domain gets team-member access
ALLOWED_DOMAINS=accenture.com,diageo.com
